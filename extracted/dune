; Coq-extracted governance kernel + clean wrapper
; Note: Ascii, Datatypes, String, PeanoNat are empty shim modules
; generated by Coq extraction but not referenced by any code.
; They are excluded to avoid shadowing OCaml stdlib modules.
(library
 (name governance_kernel)
 (modules Governance Directives TrustSpec InterpreterSpec
          EffectAlgebra CapabilityComposition
          Governance_kernel)
 (libraries stdlib)
 (flags (:standard -w -33-34-37-38-39-60)))

; Unit tests
(executable
 (name test_kernel)
 (modules Test_kernel)
 (libraries governance_kernel))
